# --- Supabase (required) ---
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SECRET_KEY=sb_secret_YOUR_KEY

# --- Data APIs (required for Phase 1) ---
ALPHA_VANTAGE_KEY=your_key_here        # free: alphavantage.co/support/#api-key
FINNHUB_KEY=your_key_here              # free: finnhub.io/register

# --- LLM (required for Phase 4) ---
ANTHROPIC_API_KEY=your_key_here        # anthropic.com/api

# --- App config ---
LOG_LEVEL=INFO
UNIVERSE=NDX100                        # NDX100 | SP500 | test5
DAILY_SCAN_HOUR=8
MAX_PICKS=10
MACRO_REGIME_GREEN_THRESHOLD=7
MACRO_REGIME_RED_THRESHOLD=3
